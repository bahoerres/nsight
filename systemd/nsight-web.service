[Unit]
Description=nsight health dashboard
After=network.target postgresql.service

[Service]
Type=simple
WorkingDirectory=%h/stacks/nsight
ExecStart=%h/stacks/nsight/.venv/bin/gunicorn -b 127.0.0.1:5100 app:app
Restart=on-failure
EnvironmentFile=%h/stacks/nsight/.env

[Install]
WantedBy=default.target
